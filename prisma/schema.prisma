// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  password  String   @db.Text
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  documents Document[]
  quizAttempts QuizAttempt[]

  @@map("users")
}

enum SourceType {
  FAQ
  ONBOARDING
  SCHEDULE
  PROGRAM_DOC
  OTHER
}

model Document {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  source      String
  sourceType  SourceType
  cohort      String?    @db.VarChar(100)
  metadata    Json?      @db.JsonB
  content     String?    @db.Text
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  
  chunks      Chunk[]
  userId      String?    @db.Uuid
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([source, title])
  @@map("documents")
}

model Chunk {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId   String   @db.Uuid
  content      String   @db.Text
  contentHash  String   @unique @db.VarChar(64)
  embedding    Json?    @db.JsonB
  //embeddingVector Unsupported("vector(1536)")?//
  chunkIndex   Int      @default(0)
  metadata     Json?    @db.JsonB
  
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([contentHash])
  @@index([documentId])
  @@map("chunks")
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Quiz {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String   @db.VarChar(255)
  description String?  @db.Text
  duration    Int      // minutes, must be > 0
  openDate    DateTime
  closeDate   DateTime
  passScore   Int?     @default(0)
  status      QuizStatus @default(DRAFT)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  attempts    QuizAttempt[]

  @@index([status])
  @@map("quizzes")
}

model QuizAttempt {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quizId      String   @db.Uuid
  userId      String   @db.Uuid
  startedAt   DateTime @default(now())
  completedAt DateTime?
  score       Int?
  
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Restrict)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([quizId, userId])
  @@map("quiz_attempts")
}